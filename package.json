{
    "name": "consultation-agent-monorepo",
    "version": "1.0.0",
    "private": true,
    "scripts": {
        "dev:frontend": "pnpm --filter @consultation-agent/frontend start",
        "dev:backend": "pnpm --filter @consultation-agent/backend dev",
        "dev": "pnpm run dev:backend & pnpm run dev:frontend",
        "build": "pnpm -r build",
        "build:backend": "pnpm --filter @consultation-agent/backend build",
        "build:frontend": "pnpm --filter @consultation-agent/frontend build",
        "lint": "pnpm -r lint",
        "lint:fix": "pnpm -r lint:fix",
        "typecheck": "pnpm -r typecheck",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "prepare": "husky",
        "commit": "git-cz"
    },
    "dependencies": {
        "ai": "^6.0.141"
    },
    "devDependencies": {
        "@commitlint/cli": "^20.5.0",
        "@commitlint/config-conventional": "^20.5.0",
        "commitizen": "^4.3.1",
        "cz-conventional-changelog": "^3.3.0",
        "husky": "^9.1.7",
        "lint-staged": "^16.4.0",
        "prettier": "^3.8.1"
    },
    "engines": {
        "node": ">=22",
        "pnpm": ">=10.32.1"
    },
    "config": {
        "commitizen": {
            "path": "./node_modules/cz-conventional-changelog"
        }
    },
    "packageManager": "pnpm@10.33.0"
}
